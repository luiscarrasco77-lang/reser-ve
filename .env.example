# ─── RESER-VE · Variables de entorno ─────────────────────────────────────────
# Copia este archivo a .env.local y rellena los valores.
# En Vercel, configúralas en Project → Settings → Environment Variables
# (o usa `vercel env pull .env.local` para traerlas a tu máquina).

# Base de datos Postgres (Neon). Requerida para reservas reales.
# Vercel la inyecta automáticamente al crear un Neon database desde Storage.
# Sin esta variable la web funciona en modo demo con datos de ejemplo.
DATABASE_URL=

# Secreto para firmar las sesiones de NextAuth. Genera uno con:  openssl rand -base64 32
AUTH_SECRET=

# Asistente de IA (Vera) vía Vercel AI Gateway.
# En despliegues de Vercel se usa OIDC automáticamente y NO hace falta esta key.
# En local, créala en Vercel → AI Gateway → API Keys.
AI_GATEWAY_API_KEY=

# Subida de fotos de posadas (Vercel Blob). Storage → Blob.
BLOB_READ_WRITE_TOKEN=

# Envío de correos transaccionales (Resend). Opcional.
RESEND_API_KEY=

# Correo del equipo que recibe las solicitudes de registro de posadas. Opcional.
TEAM_EMAIL=hola@reser-ve.com

# Protege el cron de ciclo de vida de reservas (Vercel lo envía como Bearer token).
# Genera uno con: openssl rand -hex 16
CRON_SECRET=

# URL pública del sitio para SEO/sitemap. Opcional (default https://reser-ve.com).
NEXT_PUBLIC_SITE_URL=https://reser-ve.com
